# ─────────────────────────────────────────────────────────────────────────────
# Agentic Pipeline — environment variables
# Copy this file to .env and fill in the values you need.
# Lines starting with # are comments and are ignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Ollama ────────────────────────────────────────────────────────────────────
# URL of the Ollama server. Defaults to the companion container.
# OLLAMA_HOST=http://ollama:11434

# Default model to pull and use (overrides config/config.yaml)
# DEFAULT_MODEL=qwen2.5:7b

# ── Open WebUI ────────────────────────────────────────────────────────────────
# Secret key for the WebUI session (change before exposing publicly)
# WEBUI_SECRET_KEY=changeme

# ── Cloud LLM providers (fill in when switching away from Ollama) ─────────────

# OpenAI / Azure OpenAI / Groq / Together AI / any OpenAI-compatible endpoint
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1   # optional — change for Azure/Groq

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
# GEMINI_API_KEY=AIza...

# ── Tool configuration overrides ─────────────────────────────────────────────
# SHELL_TIMEOUT=30
# PYTHON_EVAL_TIMEOUT=10
# WEB_FETCH_TIMEOUT=15
# WEB_FETCH_MAX_LENGTH=50000
# FILE_BASE_DIR=/app/workspace
